{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/harbor-hook.mjs\"",
            "command_windows": "node \"${PLUGIN_ROOT}\\scripts\\harbor-hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Starting Token Harbor"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/harbor-hook.mjs\"",
            "command_windows": "node \"${PLUGIN_ROOT}\\scripts\\harbor-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/harbor-hook.mjs\"",
            "command_windows": "node \"${PLUGIN_ROOT}\\scripts\\harbor-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/harbor-hook.mjs\"",
            "command_windows": "node \"${PLUGIN_ROOT}\\scripts\\harbor-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/harbor-hook.mjs\"",
            "command_windows": "node \"${PLUGIN_ROOT}\\scripts\\harbor-hook.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
